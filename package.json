{
  "name": "fullstack-local-runner",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "mysql:up": "docker compose -f mysql-docker/docker-compose.yml up -d",
    "mysql:down": "docker compose -f mysql-docker/docker-compose.yml down",
    "mysql:logs": "docker compose -f mysql-docker/docker-compose.yml logs -f mysql",
    "db:init": "node backend/scripts/init-db.js",
    "backend": "npm run dev --prefix backend",
    "frontend": "npm run dev --prefix frontend",
    "dev": "npm run mysql:up && npm run db:init && (npm run backend & npm run frontend & wait)"
  }
}
